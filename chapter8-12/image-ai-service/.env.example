# Google Gemini API キー（https://aistudio.google.com から取得）
GOOGLE_GENERATIVE_AI_API_KEY=your-api-key-here

# アプリの URL（Better Auth が使用）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
# 下記は `openssl rand -base64 32` などで安全なランダム文字列を生成して貼り付けてください
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Langfuse（第11章で追加）
# https://cloud.langfuse.com（または日本リージョン https://jp.cloud.langfuse.com）
# でプロジェクトを作成して取得した API キーを設定してください
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# Turso（第12章で追加。Vercelデプロイ時のみ必要。ローカルでは未設定でOK）
# 各DBごとに Turso ダッシュボードで「Create database」して接続URLとトークンを取得します
# - image-app-auth   : Better Auth（認証）
# - image-app-mastra : Mastraストレージ
# - image-app-vector : ベクトル検索
TURSO_AUTH_DATABASE_URL=
TURSO_AUTH_AUTH_TOKEN=
TURSO_MASTRA_DATABASE_URL=
TURSO_MASTRA_AUTH_TOKEN=
TURSO_VECTOR_DATABASE_URL=
TURSO_VECTOR_AUTH_TOKEN=

# Vercel Blob（第12章で追加。Vercelデプロイ時のみ必要。ローカルでは未設定でOK）
# Vercelダッシュボードのプロジェクト設定 > Storage で Blob ストアを作成すると自動発行されます
BLOB_READ_WRITE_TOKEN=
