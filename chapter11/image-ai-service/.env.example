# Google Gemini API キー（https://aistudio.google.com から取得）
GOOGLE_API_KEY=your-api-key-here

# アプリの URL（Better Auth が使用）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
# 下記は `openssl rand -base64 32` などで安全なランダム文字列を生成して貼り付けてください
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Langfuse（第11章で追加）
# https://cloud.langfuse.com（または日本リージョン https://jp.cloud.langfuse.com）
# でプロジェクトを作成して取得した API キーを設定してください
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
